{
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node"],
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "ES2018",
    "module": "ESNext",
    "lib": ["DOM", "ES2018"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
